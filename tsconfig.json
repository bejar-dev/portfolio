{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*":            ["src/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*":    ["src/layouts/*"],
      "@pages/*":      ["src/pages/*"],
      "@assets/*":     ["src/assets/*"],
      "@data/*":       ["src/data/*"],
      "@styles/*":     ["src/styles/*"],
      "@content/*":    ["src/content/*"]
    }
  }
}