---
import Button from '../../ui/Button.astro';

interface Props {
	title: string;
	description?: string;
	shortDescription: string;
	role?: string;
	experienceGroupLabel?: string;
	date: Date | string;
	liveUrl?: string;
	github?: string;
}

const {
	title,
	description,
	shortDescription,
	role,
	experienceGroupLabel,
	date,
	liveUrl,
	github
} = Astro.props;

const publishedAt = new Intl.DateTimeFormat('es-PE', {
	year: 'numeric',
	month: 'long'
}).format(new Date(date));
---

<section class="rounded-3xl bg-gradient-to-br from-primary-200 via-secondary-100 to-complement-200 p-6 shadow-sm sm:p-8 dark:from-primary-900 dark:via-secondary-900 dark:to-complement-900">
	<div class="mb-5 flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-text-700 dark:text-text-200">
		<a href="/proyectos" class="rounded-full border border-text-300 px-3 py-1 hover:bg-white/40 dark:border-text-700 dark:hover:bg-black/20">
			Volver
		</a>
		{experienceGroupLabel && (
			<span class="rounded-full border border-text-300 px-3 py-1 dark:border-text-700">{experienceGroupLabel}</span>
		)}
		<span class="rounded-full border border-text-300 px-3 py-1 dark:border-text-700">{publishedAt}</span>
	</div>

	<h1 class="max-w-4xl text-text-900 dark:text-text-50">{title}</h1>
	<p class="mt-4 max-w-3xl text-large text-text-700 dark:text-text-200">{shortDescription}</p>
	{description && <p class="mt-3 max-w-3xl text-text-700 dark:text-text-300">{description}</p>}

	<div class="mt-6 flex flex-wrap items-center gap-3">
		{role && (
			<p class="rounded-xl bg-white/60 px-4 py-2 text-sm font-medium text-text-800 dark:bg-black/30 dark:text-text-100">
				Rol: {role}
			</p>
		)}
		{liveUrl && (
			<Button href={liveUrl} external size="sm">
				Ver demo
			</Button>
		)}
		{github && (
			<Button href={github} external variant="ghost" size="sm">
				Ver codigo
			</Button>
		)}
	</div>
</section>
