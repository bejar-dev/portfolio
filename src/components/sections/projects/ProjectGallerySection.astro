---
import HeaderSection from '../../ui/HeaderSection.astro';
import Carousel from '../../ui/Carousel.astro';

interface GalleryImage {
	src: string;
	alt: string;
}

interface Props {
	images: GalleryImage[];
}

const { images } = Astro.props;
---

<section class="mt-12">
	<HeaderSection title="Capturas" subtitle="Flujo y pantallas clave del proyecto." />
	<Carousel images={images} />
</section>
