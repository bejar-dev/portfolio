---
interface Props {
	experienceGroupLabel?: string;
	experienceRoleSummary?: string;
	role?: string;
	duration?: string;
	tags: string[];
}

const { experienceGroupLabel, experienceRoleSummary, role, duration, tags } = Astro.props;
---

<section class="mt-12 rounded-2xl border border-text-200 bg-white/75 p-6 dark:border-text-800 dark:bg-text-950/70">
	<h2 class="text-title-h4 font-semibold text-text-900 dark:text-text-50">Mi participacion y alcance</h2>
	<div class="mt-4 grid gap-4 sm:grid-cols-2">
		<div>
			{experienceGroupLabel && (
				<p class="text-small text-text-600 dark:text-text-300">
					Contexto laboral: <span class="font-semibold text-text-800 dark:text-text-100">{experienceGroupLabel}</span>
				</p>
			)}
			{role && (
				<p class="mt-2 text-text-700 dark:text-text-200">
					Rol principal: <span class="font-semibold">{role}</span>
				</p>
			)}
			{duration && <p class="mt-2 text-small text-text-600 dark:text-text-300">Duracion: {duration}</p>}
		</div>
		{experienceRoleSummary && (
			<p class="text-text-700 dark:text-text-200">{experienceRoleSummary}</p>
		)}
	</div>

	<div class="mt-5 flex flex-wrap gap-2">
		{tags.map((tag) => (
			<span class="rounded-full bg-primary-100 px-3 py-1.5 text-xs font-semibold text-primary-700 dark:bg-primary-900 dark:text-primary-200">
				{tag}
			</span>
		))}
	</div>
</section>
