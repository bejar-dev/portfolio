---
interface Props {
	problem?: string;
	solution?: string;
}

const { problem, solution } = Astro.props;
---

<section class="mt-12 grid gap-4 lg:grid-cols-2">
	{problem && (
		<article class="rounded-2xl border border-text-200 bg-white/75 p-6 dark:border-text-800 dark:bg-text-950/70">
			<h2 class="text-title-h4 font-semibold text-text-900 dark:text-text-50">Problema</h2>
			<p class="mt-3 text-text-700 dark:text-text-200">{problem}</p>
		</article>
	)}
	{solution && (
		<article class="rounded-2xl border border-primary-200 bg-primary-50/70 p-6 dark:border-primary-800 dark:bg-primary-950/40">
			<h2 class="text-title-h4 font-semibold text-text-900 dark:text-text-50">Solucion</h2>
			<p class="mt-3 text-text-700 dark:text-text-200">{solution}</p>
		</article>
	)}
</section>
