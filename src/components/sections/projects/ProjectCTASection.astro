---
import Button from '../../ui/Button.astro';

interface Props {
	liveUrl?: string;
	github?: string;
	cta?: {
		text: string;
		href: string;
	};
}

const { liveUrl, github, cta } = Astro.props;
---

<section class="mt-12 rounded-2xl border border-text-200 bg-white/80 p-6 dark:border-text-800 dark:bg-text-950/70">
	<h2 class="text-title-h4 font-semibold text-text-900 dark:text-text-50">Siguiente paso</h2>
	<p class="mt-3 text-text-700 dark:text-text-200">
		Si quieres evaluar mi experiencia para una posicion, este proyecto refleja como convierto decisiones
		técnicas en resultados visibles.
	</p>
	<div class="mt-5 flex flex-wrap gap-3">
		{liveUrl && (
			<Button href={liveUrl} external>
				Revisar demo
			</Button>
		)}
		{github && (
			<Button href={github} external variant="ghost">
				Ver repositorio
			</Button>
		)}
		{cta && (
			<Button href={cta.href} variant="secondary">
				{cta.text}
			</Button>
		)}
	</div>
</section>
