---
import MainContainerSection from '../../../ui/MainContainerSection.astro';
import HeaderSection from '../../../ui/HeaderSection.astro';
import { experience } from '../../../../data/experience';
---

<MainContainerSection id="experiencia">
	<HeaderSection title="Experiencia" subtitle="Trayectoria y proyectos profesionales" />

	<div class="relative space-y-8 before:absolute before:left-4 before:top-0 before:h-full before:w-px before:bg-text-300 dark:before:bg-text-700 sm:before:left-1/2">
		{experience.map((item) => (
			<article class="relative rounded-2xl border border-text-200 bg-white/80 p-6 shadow-sm dark:border-text-800 dark:bg-text-950/70 sm:mx-auto sm:max-w-3xl">
				<span class="absolute left-2 top-6 h-4 w-4 rounded-full bg-primary-500 ring-4 ring-white dark:ring-text-950 sm:left-1/2 sm:-translate-x-1/2"></span>

				<p class="text-small font-semibold uppercase tracking-wide text-secondary-600 dark:text-secondary-300">
					{item.startDate} - {item.endDate}
				</p>
				<h3 class="mt-2 font-bold text-text-900 dark:text-text-50">{item.role}</h3>
				<p class="mt-1 text-text-600 dark:text-text-300">{item.company}</p>

				<ul class="mt-4 list-disc space-y-2 pl-5 text-text-700 dark:text-text-200">
					{item.description.map((point) => (
						<li>{point}</li>
					))}
				</ul>

				<div class="mt-4 flex flex-wrap gap-2">
					{item.technologies.map((tech) => (
						<span class="rounded-full border border-complement-400/45 bg-complement-100 px-2.5 py-1 text-xs font-semibold text-complement-800 dark:border-complement-700 dark:bg-complement-900/45 dark:text-complement-200">
							{tech}
						</span>
					))}
				</div>
			</article>
		))}
	</div>
</MainContainerSection>
