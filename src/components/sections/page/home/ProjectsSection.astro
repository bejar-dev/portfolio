---
import { getCollection } from 'astro:content';
import { Link2, Globe } from '@lucide/astro';
import MainContainerSection from '../../../ui/MainContainerSection.astro';
import HeaderSection from '../../../ui/HeaderSection.astro';
import Button from '../../../ui/Button.astro';

const featuredProjects = (await getCollection('projects'))
	.filter((project) => project.data.featured)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<MainContainerSection id="proyectos">
	<HeaderSection title="Proyectos" subtitle="Algunos trabajos recientes" />

	<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
		{featuredProjects.map((project) => (
			<article class="flex h-full flex-col rounded-2xl border border-text-200 bg-white/75 p-5 shadow-sm transition hover:-translate-y-1 dark:border-text-800 dark:bg-text-950/70">
				<div class="mb-4 rounded-xl bg-gradient-to-br from-primary-200 via-secondary-100 to-complement-200 p-6 text-text-900 dark:from-primary-900 dark:via-secondary-900 dark:to-complement-900 dark:text-text-50">
					<h3 class="font-bold">{project.data.title}</h3>
					<p class="mt-1 text-small opacity-80">Vista previa del proyecto</p>
				</div>

				<p class="text-text-700 dark:text-text-200">{project.data.shortDescription}</p>

				<div class="mt-4 flex flex-wrap gap-2">
					{project.data.tags.map((tag) => (
						<span class="rounded-full bg-primary-100 px-2.5 py-1 text-xs font-semibold text-primary-700 dark:bg-primary-900 dark:text-primary-200">
							{tag}
						</span>
					))}
				</div>

				<div class="mt-auto flex items-center gap-2 pt-5">
					{project.data.github && (
						<a
							href={project.data.github}
							target="_blank"
							rel="noopener noreferrer"
							class="rounded-full border border-text-300 p-2 text-text-700 hover:bg-text-100 dark:border-text-700 dark:text-text-200 dark:hover:bg-text-900"
							aria-label={`Repositorio del proyecto ${project.data.title}`}
						>
							  <Link2 size={18} />
						</a>
					)}
					{project.data.liveUrl && (
						<a
							href={project.data.liveUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="rounded-full border border-text-300 p-2 text-text-700 hover:bg-text-100 dark:border-text-700 dark:text-text-200 dark:hover:bg-text-900"
							aria-label={`Demo del proyecto ${project.data.title}`}
						>
							<Globe size={18} />
						</a>
					)}
				</div>
			</article>
		))}
	</div>

	<div class="mt-10">
		<Button href="/proyectos" variant="ghost">Ver todos →</Button>
	</div>
</MainContainerSection>
