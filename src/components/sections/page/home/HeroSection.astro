---
import MainContainerSection from '../../../ui/MainContainerSection.astro';
import Button from '../../../ui/Button.astro';
import { personal } from '../../../../data/personal';
import { Image } from 'astro:assets';

const initials = personal.name
	.split(' ')
	.filter(Boolean)
	.slice(0, 2)
	.map((part) => part[0]?.toUpperCase() ?? '')
	.join('');

// Import Image
import imgHeroWeb from '../../../../assets/images/image-initial-hero-web-design.png';
---

<MainContainerSection class="pt-20 sm:pt-28">
	<div class="grid items-center gap-10 md:grid-cols-2">
		<div class="space-y-5">
			<p class="motion-safe:animate-fade-up text-small uppercase tracking-[0.18em] text-secondary-600 dark:text-secondary-300">
				Hola, soy
			</p>
			<h1 class="motion-safe:animate-fade-up font-extrabold text-text-900 dark:text-text-50 animation-delay-[80ms] text-balance">
				{personal.name}
			</h1>
			<p class="motion-safe:animate-fade-up mt-3 text-large font-semibold text-primary-600 dark:text-primary-300 animation-delay-[120ms]">
				{personal.role}
			</p>
			<p class="motion-safe:animate-fade-up max-w-xl text-text-600 dark:text-text-300 animation-delay-[180ms]">
				{personal.bio}
			</p>

			<div class="motion-safe:animate-fade-up flex flex-wrap gap-3 animation-delay-[240ms]">
				<Button href="/proyectos">Ver proyectos</Button>
				<Button href="/sobre-mi" variant="ghost">Sobre mi</Button>
			</div>
		</div>

		<div class="motion-safe:animate-fade-up animation-delay-[140ms] bg-radial from-5% from-purple-400 via-25% via-purple-400/50 to-65% to-transparent">
			<!-- <div class="mx-auto flex aspect-square w-52 items-center justify-center rounded-full border border-primary-300/60 bg-linear-to-br from-primary-200 to-secondary-200 text-6xl font-bold text-text-900 shadow-xl dark:border-primary-700/50 dark:from-primary-900 dark:to-secondary-900 dark:text-text-50">
				{initials}
			</div> -->
			<Image
				src={imgHeroWeb}
				alt="Diseño y desarrollo web en Astro y WordPress"
				width={1000}
				height={1000}
				format='webp'
				loading='eager'
				fetchpriority='high'
				class='m-auto'
			/>
		</div>
	</div>
</MainContainerSection>
