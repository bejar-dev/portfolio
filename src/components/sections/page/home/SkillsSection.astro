---
import MainContainerSection from '../../../ui/MainContainerSection.astro';
import HeaderSection from '../../../ui/HeaderSection.astro';
import Icon from '../../../ui/Icon.astro';
import { BarChart3, Code2, Palette, PenTool, Rocket, Server } from '@lucide/astro';
import { skills } from '../../../../data/skills';

const levelLabel = {
	beginner: 'Inicial',
	intermediate: 'Intermedio',
	advanced: 'Avanzado'
} as const;

const levelConfig = {
	advanced: { 
		badge: 'bg-gradient-to-r from-primary-500 to-primary-600 text-white' 
	},
	intermediate: { 
		badge: 'bg-gradient-to-r from-amber-400 to-amber-500 text-white'
	},
	beginner: { 
		badge: 'bg-gradient-to-r from-slate-400 to-slate-500 text-white'
	}
} as const;

const categoryIconMap = {
	Code2,
	Palette,
	Server,
	Rocket,
	BarChart3,
	PenTool
} as const;
---

<MainContainerSection id="skills">
	<HeaderSection title="Habilidades" subtitle="Tecnologías y herramientas profesionales" />
	
	<style>
		/* Escala tipográfica desde global.css */
		.skill-category-title {
			font-size: var(--title-h3);
			font-weight: 700;
			line-height: 1.2;
		}

		.skill-name {
			font-size: var(--text-base);
			font-weight: 600;
		}

		.skill-badge {
			font-size: var(--text-small);
			font-weight: 700;
		}

		.stats-number {
			font-size: var(--title-h2);
			font-weight: 800;
		}

		.stats-label {
			font-size: var(--text-small);
			font-weight: 600;
		}

		/* Animaciones con tailwind-animations */
		.skill-category {
			animation: fade-in slide-in-up 0.6s ease-out forwards;
		}

		.skill-card {
			position: relative;
			overflow: hidden;
			transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		}

		.skill-card:hover {
			transform: translateY(-6px);
		}

		.skill-icon {
			animation: none;
			transition: transform 0.3s ease;
		}

		.skill-card:hover .skill-icon {
			animation: pulse 2s ease-in-out infinite;
			transform: scale(1.05);
		}

		@media (max-width: 768px) {
			.skill-card {
				transition: all 0.2s ease;
			}
			.skill-card:active {
				transform: scale(0.95);
			}
		}
	</style>

	<!-- Contenedor principal de categorías -->
	<div class="space-y-10 md:space-y-14">
		{skills.map((category, catIdx) => {
			const CategoryIcon = categoryIconMap[category.categoryIcon];

			return (
			<section class="skill-category" style={`animation-delay: ${catIdx * 80}ms`}>
				<!-- Header de categoría con línea decorativa -->
				<div class="mb-6 flex items-center gap-3 md:mb-8">
					<div class="flex h-9 w-9 items-center justify-center rounded-xl border border-primary-200/60 bg-primary-100/40 text-primary-700 dark:border-primary-800/60 dark:bg-primary-900/30 dark:text-primary-300">
						<CategoryIcon size={18} stroke-width={2} />
					</div>
					<div class="h-1 w-12 rounded-full bg-linear-to-r from-primary-500 via-primary-600 to-transparent"></div>
					<h2 class="skill-category-title text-text-900 dark:text-text-50">
						{category.category}
					</h2>
				</div>

				<!-- Grid de skills responsive y estratégico -->
				<div class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4">
					{category.skills.map((skill, skillIdx) => {
						const config = levelConfig[skill.level];
						
						return (
							<div
								class="skill-card group relative rounded-2xl bg-white/40 dark:bg-text-900/40 border border-text-100/50 dark:border-text-800/50 backdrop-blur-md p-4 md:p-5 overflow-hidden"
								style={`animation-delay: ${(catIdx * 80 + skillIdx * 25)}ms`}
							>
								<div class="flex flex-col h-full gap-3">
									<!-- Ícono con background degradado -->
									{skill.iconName && (
										<div class="skill-icon flex justify-center items-center w-full">
											<div class="relative flex items-center justify-center transition-all duration-300 group-hover:scale-105">
												<Icon 
													name={skill.iconName}
													class={`w-9 h-9 md:w-10 md:h-10 [&_svg]:w-full [&_svg]:h-full [&_svg]:object-contain ${skill.iconName === 'astro-icon' ? 'text-text-900 dark:text-white' : ''}`}
												/>
											</div>
										</div>
									)}

									<!-- Contenido textual -->
									<div class="flex flex-col gap-2 flex-1">
										<!-- Nombre tech -->
										<h3 class="skill-name text-text-900 dark:text-text-50 text-center line-clamp-2 leading-tight">
											{skill.name}
										</h3>

									</div>
								</div>

								<!-- Borde luminoso en hover -->
								<div class="absolute inset-0 rounded-2xl border border-primary-300/0 group-hover:border-primary-300/50 dark:group-hover:border-primary-400/30 transition-all duration-300 pointer-events-none"></div>
							</div>
						);
					})}
				</div>
			</section>
			);
		})}
	</div>
</MainContainerSection>
