---
import MainContainerSection from '../../../ui/MainContainerSection.astro';
import HeaderSection from '../../../ui/HeaderSection.astro';
import { skills } from '../../../../data/skills';

const levelLabel = {
	beginner: 'Inicial',
	intermediate: 'Intermedio',
	advanced: 'Avanzado'
} as const;
---

<MainContainerSection id="skills">
	<HeaderSection title="Habilidades" subtitle="Tecnologias con las que trabajo" />

	<div class="grid gap-6 lg:grid-cols-3">
		{skills.map((category) => (
			<article class="rounded-2xl border border-text-200 bg-white/75 p-5 shadow-sm dark:border-text-800 dark:bg-text-950/70">
				<h3 class="mb-4 font-bold text-text-900 dark:text-text-50">{category.category}</h3>
				<ul class="space-y-3">
					{category.skills.map((skill) => (
						<li class="flex items-center justify-between rounded-xl bg-text-50 px-3 py-2 dark:bg-text-900">
							<span class="font-medium text-text-800 dark:text-text-100">{skill.name}</span>
							<span class="rounded-full bg-primary-100 px-2.5 py-1 text-xs font-semibold text-primary-700 dark:bg-primary-900 dark:text-primary-200">
								{levelLabel[skill.level]}
							</span>
						</li>
					))}
				</ul>
			</article>
		))}
	</div>
</MainContainerSection>
