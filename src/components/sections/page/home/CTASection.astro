---
import MainContainerSection from '../../../ui/MainContainerSection.astro';
import HeaderSection from '../../../ui/HeaderSection.astro';
import Button from '../../../ui/Button.astro';
import { personal } from '../../../../data/personal';
---

<MainContainerSection id="contacto">
	<div class="rounded-3xl border border-text-200 bg-white/80 p-6 shadow-sm dark:border-text-800 dark:bg-text-950/70 sm:p-10">
		<HeaderSection
			title="Trabajemos juntos"
			subtitle="Cuantame sobre tu proyecto y te respondere en cuanto pueda."
		/>

		{personal.availableForWork ? (
			<p class="mb-6 inline-flex rounded-full bg-complement-100 px-3 py-1 text-small font-semibold text-complement-800 dark:bg-complement-900/45 dark:text-complement-200">
				Disponible para nuevos proyectos
			</p>
		) : (
			<p class="mb-6 inline-flex rounded-full bg-secondary-100 px-3 py-1 text-small font-semibold text-secondary-800 dark:bg-secondary-900/45 dark:text-secondary-200">
				Agenda completa temporalmente
			</p>
		)}

		<form id="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-4">
			<label class="block">
				<span class="mb-1 block font-medium text-text-700 dark:text-text-200">Nombre</span>
				<input
					type="text"
					name="name"
					required
					class="w-full rounded-xl border border-text-300 bg-white px-4 py-2.5 text-text-900 dark:border-text-700 dark:bg-text-900 dark:text-text-50"
				/>
			</label>

			<label class="block">
				<span class="mb-1 block font-medium text-text-700 dark:text-text-200">Email</span>
				<input
					type="email"
					name="email"
					required
					class="w-full rounded-xl border border-text-300 bg-white px-4 py-2.5 text-text-900 dark:border-text-700 dark:bg-text-900 dark:text-text-50"
				/>
			</label>

			<label class="block">
				<span class="mb-1 block font-medium text-text-700 dark:text-text-200">Mensaje</span>
				<textarea
					name="message"
					required
					minlength="20"
					rows="5"
					class="w-full rounded-xl border border-text-300 bg-white px-4 py-2.5 text-text-900 dark:border-text-700 dark:bg-text-900 dark:text-text-50"
				></textarea>
			</label>

			<div class="flex items-center gap-3">
				<Button type="submit">Enviar mensaje</Button>
				<p id="contact-loading" class="hidden text-small text-text-600 dark:text-text-300">Enviando...</p>
			</div>
		</form>

		<p id="contact-success" class="mt-4 hidden rounded-xl bg-complement-100 px-4 py-3 text-complement-800 dark:bg-complement-900/45 dark:text-complement-200">
			Mensaje enviado. Te respondere muy pronto.
		</p>
		<p id="contact-error" class="mt-4 hidden rounded-xl bg-secondary-100 px-4 py-3 text-secondary-800 dark:bg-secondary-900/45 dark:text-secondary-200">
			Ocurrio un error al enviar. Intenta nuevamente en unos minutos.
		</p>

		<div class="mt-6 flex gap-4 text-small">
			<a
				href={personal.social.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="font-semibold text-primary-700 hover:underline dark:text-primary-300"
			>
				LinkedIn
			</a>
			<a
				href={personal.social.github}
				target="_blank"
				rel="noopener noreferrer"
				class="font-semibold text-primary-700 hover:underline dark:text-primary-300"
			>
				GitHub
			</a>
		</div>
	</div>
</MainContainerSection>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	const loading = document.getElementById('contact-loading');
	const success = document.getElementById('contact-success');
	const error = document.getElementById('contact-error');

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		loading?.classList.remove('hidden');
		success?.classList.add('hidden');
		error?.classList.add('hidden');

		const res = await fetch(form.action, {
			method: 'POST',
			body: new FormData(form),
			headers: { Accept: 'application/json' }
		});

		loading?.classList.add('hidden');

		if (res.ok) {
			form.reset();
			success?.classList.remove('hidden');
			form.classList.add('hidden');
		} else {
			error?.classList.remove('hidden');
		}
	});
</script>
