---
import MainContainerSection from '../../../ui/MainContainerSection.astro';
import HeaderSection from '../../../ui/HeaderSection.astro';
import Button from '../../../ui/Button.astro';
import { personal } from '../../../../data/personal';
---

<MainContainerSection id="contacto">
	<div class="rounded-3xl border border-text-200 bg-white/80 p-6 shadow-sm dark:border-text-800 dark:bg-text-950/70 sm:p-10">
		<div class="grid gap-8 lg:grid-cols-2 lg:items-start">
			<div class="space-y-6 flex flex-col gap-6">
				<HeaderSection
					title="Trabajemos juntos"
					subtitle="Cuantame sobre tu proyecto y te respondere en cuanto pueda."
				/>

				{personal.availableForWork ? (
					<p class="inline-flex rounded-full w-fit bg-complement-100 px-3 py-1 text-small font-semibold text-complement-800 dark:bg-complement-900/45 dark:text-complement-200">
						Disponible para nuevos proyectos
					</p>
				) : (
					<p class="inline-flex rounded-full bg-secondary-100 px-3 py-1 text-small font-semibold text-secondary-800 dark:bg-secondary-900/45 dark:text-secondary-200">
						Agenda completa temporalmente
					</p>
				)}

				<div class="flex flex-wrap gap-3">
					<Button href={`mailto:${personal.email}`} size="sm">Escribirme por email</Button>
					<Button href={personal.social.linkedin} external variant="ghost" size="sm">LinkedIn</Button>
					<Button href={personal.social.github} external variant="ghost" size="sm">GitHub</Button>
				</div>

				<p class="max-w-md text-base text-text-700 dark:text-text-200">
					Si prefieres, tambien puedes enviarme los detalles por el formulario para responderte con una propuesta clara.
				</p>
			</div>

			<div>
				<h3 class="mb-4 text-h3 font-semibold text-text-900 dark:text-text-50">Cuentame tu proyecto</h3>

				<form id="contact-form" action={`https://formsubmit.co/ajax/${personal.email}`} method="POST" class="space-y-4">
					<input type="hidden" name="_subject" value="Nuevo mensaje desde portfolio" />
					<input type="hidden" name="_template" value="table" />
					<input type="hidden" name="_captcha" value="false" />

					<label class="block">
						<span class="mb-1 block font-medium text-text-700 dark:text-text-200">Nombre</span>
						<input
							type="text"
							name="name"
							required
							class="w-full rounded-xl border border-text-300 bg-white px-4 py-2.5 text-text-900 dark:border-text-700 dark:bg-text-900 dark:text-text-50"
						/>
					</label>

					<label class="block">
						<span class="mb-1 block font-medium text-text-700 dark:text-text-200">Email</span>
						<input
							type="email"
							name="email"
							required
							class="w-full rounded-xl border border-text-300 bg-white px-4 py-2.5 text-text-900 dark:border-text-700 dark:bg-text-900 dark:text-text-50"
						/>
					</label>

					<label class="block">
						<span class="mb-1 block font-medium text-text-700 dark:text-text-200">Mensaje</span>
						<textarea
							name="message"
							required
							minlength="20"
							rows="5"
							class="w-full rounded-xl border border-text-300 bg-white px-4 py-2.5 text-text-900 dark:border-text-700 dark:bg-text-900 dark:text-text-50"
						></textarea>
					</label>

					<div class="flex items-center gap-3">
						<Button type="submit">Enviar mensaje</Button>
						<p id="contact-loading" class="hidden text-small text-text-600 dark:text-text-300">Enviando...</p>
					</div>
				</form>

				<div
					id="contact-success"
					class="mt-2 hidden rounded-2xl bg-complement-100 px-4 py-4 text-center text-complement-800 dark:bg-complement-900/45 dark:text-complement-200"
				>
					<div class="mx-auto mb-2 inline-flex h-10 w-10 items-center justify-center rounded-full bg-complement-200 dark:bg-complement-900/60">
						<svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
							<path
								fill-rule="evenodd"
								d="M16.704 5.29a1 1 0 010 1.42l-7.2 7.2a1 1 0 01-1.415 0l-3-3a1 1 0 111.415-1.42l2.292 2.294l6.492-6.494a1 1 0 011.416 0z"
								clip-rule="evenodd"
							></path>
						</svg>
					</div>
					<p class="text-small font-semibold">Mensaje enviado con exito.</p>
					<p class="mt-1 text-small">Te respondere muy pronto.</p>
				</div>
				<p id="contact-error" class="mt-4 hidden rounded-xl bg-secondary-100 px-4 py-3 text-secondary-800 dark:bg-secondary-900/45 dark:text-secondary-200">
					Ocurrio un error al enviar. Intenta nuevamente en unos minutos.
				</p>
			</div>
		</div>
	</div>
</MainContainerSection>

<script>
	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	const loading = document.getElementById('contact-loading');
	const success = document.getElementById('contact-success');
	const error = document.getElementById('contact-error');

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();

		loading?.classList.remove('hidden');
		success?.classList.add('hidden');
		error?.classList.add('hidden');

		const res = await fetch(form.action, {
			method: 'POST',
			body: new FormData(form),
			headers: { Accept: 'application/json' }
		});

		loading?.classList.add('hidden');

		if (res.ok) {
			form.reset();
			success?.classList.remove('hidden');
			form.classList.add('hidden');
		} else {
			error?.classList.remove('hidden');
		}
	});
</script>
