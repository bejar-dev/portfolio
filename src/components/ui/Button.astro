---
interface Props {
	href?: string;
	variant?: 'primary' | 'secondary' | 'ghost';
	size?: 'sm' | 'md' | 'lg';
	external?: boolean;
	class?: string;
	[key: string]: any;
}

const {
	href,
	variant = 'primary',
	size = 'md',
	external = false,
	class: className,
	...rest
} = Astro.props;

const baseClass =
	'group relative inline-flex items-center justify-center overflow-hidden rounded-full font-semibold tracking-tight transition-all duration-300 focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 motion-safe:hover:-translate-y-0.5 disabled:pointer-events-none disabled:opacity-60 before:pointer-events-none before:absolute before:inset-y-0 before:-left-1/3 before:w-1/3 before:skew-x-[-20deg] before:bg-gradient-to-r before:from-transparent before:via-white/70 before:to-transparent before:opacity-0 before:transition-all before:duration-500 motion-safe:hover:before:left-[125%] motion-safe:hover:before:opacity-100';

const variantClass = {
	primary:
		'bg-gradient-to-r from-primary-900 to-primary-700 text-white shadow-[0_8px_20px_-10px_rgba(49,46,129,0.75)] hover:from-primary-800 hover:to-primary-700 hover:shadow-[0_14px_28px_-14px_rgba(49,46,129,0.88)] dark:from-primary-700 dark:to-primary-500 dark:hover:from-primary-600 dark:hover:to-primary-500',
	secondary:
		'bg-gradient-to-r from-secondary-600 to-secondary-500 text-white shadow-[0_8px_20px_-10px_rgba(190,24,93,0.65)] hover:from-secondary-700 hover:to-secondary-600 hover:shadow-[0_14px_28px_-14px_rgba(190,24,93,0.8)] dark:from-secondary-500 dark:to-secondary-400 dark:hover:from-secondary-400 dark:hover:to-secondary-300',
	ghost:
		'border border-text-300/90 bg-white/70 text-text-800 shadow-sm hover:border-primary-300 hover:bg-primary-50 hover:text-primary-800 dark:border-text-700 dark:bg-text-950/60 dark:text-text-100 dark:hover:border-primary-700 dark:hover:bg-primary-950/35 dark:hover:text-primary-200'
}[variant];

const sizeClass = {
	sm: 'px-4 py-2 text-sm leading-none',
	md: 'px-5.5 py-2.5 text-sm sm:text-base leading-none',
	lg: 'px-7 py-3 text-base sm:text-lg leading-none'
}[size];
---

{
	href ? (
		<a
			href={href}
			target={external ? '_blank' : undefined}
			rel={external ? 'noopener noreferrer' : undefined}
			class:list={[baseClass, variantClass, sizeClass, className]}
			{...rest}
		>
			<slot />
		</a>
	) : (
		<button class:list={[baseClass, variantClass, sizeClass, className]} {...rest}>
			<slot />
		</button>
	)
}
