---
// src/components/ui/LogoWeb.astro
import { Image } from 'astro:assets';
import logoSrc from '@assets/images/logotipo-bejar-dev.png';

interface Props {
  /**
   * Activa carga prioritaria (eager + high fetchpriority).
   * Úsalo en el Header o cualquier sección above-the-fold.
   * Por defecto: false (lazy load para secciones secundarias).
   */
  priority?: boolean;
  /** Ancho en px. Por defecto: 140 */
  width?: number;
  /** Alto en px. Por defecto: 40 */
  height?: number;
  /** Clases adicionales de Tailwind */
  class?: string;
}

const {
  priority = false,
  width = 50,
  height = 50,
  class: className,
} = Astro.props;
---

<a href="/" class="flex gap-2 items-center hover:scale-105 transition-all duration-300 ease-in-out" aria-label="Brayan Bejar — Desarrollador Web Astro y WordPress">
  <Image
    src={logoSrc}
    alt="Brayan Bejar — Desarrollador Web Astro y WordPress"
    width={width}
    height={height}
    format="webp"
    quality={90}
    loading={priority ? 'eager' : 'lazy'}
    fetchpriority={priority ? 'high' : 'low'}
    decoding={priority ? 'sync' : 'async'}
    class:list={['object-contain', className]}
  />
  <span
    class="font-black text-large text-text-900 dark:text-text-50 transition-colors"
  >
    BR Code
  </span>
</a>