---
interface Props {
	title: string;
	subtitle?: string;
	align?: 'left' | 'center';
}

const { title, subtitle, align = 'left' } = Astro.props;
---

<header class:list={['mb-10', align === 'center' ? 'text-center' : 'text-left']}>
	<h2 class="font-bold text-text-900 dark:text-text-50">{title}</h2>
	{subtitle && (
		<p class:list={['mt-3 max-w-2xl text-large text-text-600 dark:text-text-300', align === 'center' && 'mx-auto']}>
			{subtitle}
		</p>
	)}
</header>
