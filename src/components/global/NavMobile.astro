---
import { Menu, X } from '@lucide/astro';

const links = [
	{ href: '/', label: 'Inicio' },
	{ href: '/sobre-mi', label: 'Sobre mi' },
	{ href: '/skills', label: 'Skills' },
	{ href: '/proyectos', label: 'Proyectos' }
];
---

<div class="md:hidden">
	<button
		id="mobile-menu-toggle"
		type="button"
		class="rounded-full border border-text-300 p-2 text-text-900 dark:border-text-700 dark:text-text-100"
		aria-label="Abrir menu movil"
		aria-expanded="false"
		aria-controls="mobile-menu-panel"
	>
		<span data-menu-icon="open"><Menu size={20} /></span>
		<span data-menu-icon="close" class="hidden"><X size={20} /></span>
	</button>

	<div
		id="mobile-menu-backdrop"
		class="pointer-events-none fixed inset-0 z-40 bg-black/50 opacity-0 transition duration-200"
		aria-hidden="true"
	></div>

	<aside
		id="mobile-menu-panel"
		class="pointer-events-none fixed right-0 top-0 z-50 h-full w-72 translate-x-full border-l border-text-200 bg-white p-6 shadow-xl transition duration-300 ease-out dark:border-text-800 dark:bg-text-950"
	>
		<nav class="mt-16" aria-label="Navegacion movil">
			<ul class="space-y-2">
				{links.map((link) => (
					<li>
						<a
							href={link.href}
							class="block rounded-xl px-3 py-2 text-lg font-medium text-text-800 transition hover:bg-text-100 dark:text-text-100 dark:hover:bg-text-900"
							data-mobile-link
						>
							{link.label}
						</a>
					</li>
				))}
			</ul>
		</nav>
	</aside>
</div>

<script>
	const btn = document.getElementById('mobile-menu-toggle');
	const panel = document.getElementById('mobile-menu-panel');
	const backdrop = document.getElementById('mobile-menu-backdrop');
	const openIcon = document.querySelector('[data-menu-icon="open"]');
	const closeIcon = document.querySelector('[data-menu-icon="close"]');
	const links = document.querySelectorAll('[data-mobile-link]');

	const closeMenu = () => {
		panel?.classList.add('translate-x-full', 'pointer-events-none');
		panel?.classList.remove('translate-x-0', 'pointer-events-auto', 'motion-safe:animate-slide-out-right');
		backdrop?.classList.add('opacity-0', 'pointer-events-none');
		backdrop?.classList.remove('opacity-100', 'pointer-events-auto');
		btn?.setAttribute('aria-expanded', 'false');
		openIcon?.classList.remove('hidden');
		closeIcon?.classList.add('hidden');
	};

	const openMenu = () => {
		panel?.classList.remove('translate-x-full', 'pointer-events-none');
		panel?.classList.add('translate-x-0', 'pointer-events-auto', 'motion-safe:animate-slide-in-right');
		backdrop?.classList.remove('opacity-0', 'pointer-events-none');
		backdrop?.classList.add('opacity-100', 'pointer-events-auto');
		btn?.setAttribute('aria-expanded', 'true');
		openIcon?.classList.add('hidden');
		closeIcon?.classList.remove('hidden');
	};

	btn?.addEventListener('click', () => {
		const expanded = btn.getAttribute('aria-expanded') === 'true';
		if (expanded) {
			closeMenu();
		} else {
			openMenu();
		}
	});

	backdrop?.addEventListener('click', closeMenu);
	links.forEach((link) => link.addEventListener('click', closeMenu));
	window.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeMenu();
	});
</script>
