---
import { getCollection } from 'astro:content';
import { Link2, Globe } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MainContainerSection from '../../components/ui/MainContainerSection.astro';
import HeaderSection from '../../components/ui/HeaderSection.astro';

const groupLabels: Record<string, string> = {
	'bcp-consulting-eirl': 'BCP Consulting EIRL',
	'consigue-ventas-eirl': 'Consigue Ventas EIRL',
	'creanding-eirl': 'Creanding EIRL',
	'orbita-labs': 'Orbita Labs',
	independiente: 'Proyectos independientes'
};

const groupOrder = [
	'bcp-consulting-eirl',
	'consigue-ventas-eirl',
	'creanding-eirl',
	'orbita-labs',
	'independiente'
];

const allProjects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const tags = [...new Set(allProjects.flatMap((project) => project.data.tags))].sort();

const groupedProjects = allProjects.reduce<Record<string, typeof allProjects>>((acc, project) => {
	const key = project.data.experienceGroup ?? 'independiente';
	if (!acc[key]) acc[key] = [];
	acc[key].push(project);
	return acc;
}, {});

const orderedGroups = Object.entries(groupedProjects).sort((a, b) => {
	const indexA = groupOrder.indexOf(a[0]);
	const indexB = groupOrder.indexOf(b[0]);
	const safeA = indexA === -1 ? groupOrder.length : indexA;
	const safeB = indexB === -1 ? groupOrder.length : indexB;
	return safeA - safeB;
});
---

<BaseLayout title="Proyectos">
	<MainContainerSection class="pt-20">
		<HeaderSection
			title="Proyectos"
			subtitle="Agrupados por experiencia laboral para mostrar contexto y nivel de responsabilidad."
		/>

		<div class="mb-8 flex flex-wrap gap-2" aria-label="Filtrar proyectos por tag">
			<button
				type="button"
				class="rounded-full border border-text-300 px-4 py-2 text-sm font-medium transition hover:bg-text-100 dark:border-text-700 dark:hover:bg-text-900"
				data-tag-filter="all"
				data-active="true"
			>
				Todos
			</button>
			{tags.map((tag) => (
				<button
					type="button"
					class="rounded-full border border-text-300 px-4 py-2 text-sm font-medium transition hover:bg-text-100 dark:border-text-700 dark:hover:bg-text-900"
					data-tag-filter={tag}
				>
					{tag}
				</button>
			))}
		</div>

		<div class="space-y-10" id="project-groups">
			{orderedGroups.map(([groupKey, projects]) => (
				<section data-project-group={groupKey}>
					<div class="mb-5 flex items-center justify-between gap-3">
						<h2 class="text-title-h4 font-semibold text-text-900 dark:text-text-50">
							{groupLabels[groupKey] ?? groupKey}
						</h2>
						<span class="rounded-full bg-primary-100 px-3 py-1 text-xs font-semibold text-primary-700 dark:bg-primary-900 dark:text-primary-200">
							{projects.length} proyecto{projects.length === 1 ? '' : 's'}
						</span>
					</div>

					<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
						{projects.map((project) => (
							<article
								class="flex h-full flex-col rounded-2xl border border-text-200 bg-white/75 p-5 shadow-sm dark:border-text-800 dark:bg-text-950/70"
								data-project-card
								data-project-tags={project.data.tags.join('|')}
							>
								<a href={`/proyectos/${project.id}/`} class="group block">
									<div class="mb-4 rounded-xl bg-gradient-to-br from-primary-200 via-secondary-100 to-complement-200 p-6 dark:from-primary-900 dark:via-secondary-900 dark:to-complement-900">
										<h3 class="font-bold text-text-900 group-hover:underline dark:text-text-50">{project.data.title}</h3>
									</div>
								</a>

								<p class="text-text-700 dark:text-text-200">{project.data.shortDescription}</p>

								<div class="mt-4 flex flex-wrap gap-2">
									{project.data.tags.map((tag) => (
										<span class="rounded-full bg-primary-100 px-2.5 py-1 text-xs font-semibold text-primary-700 dark:bg-primary-900 dark:text-primary-200">
											{tag}
										</span>
									))}
								</div>

								<div class="mt-auto flex items-center gap-2 pt-5">
									{project.data.github && (
										<a
											href={project.data.github}
											target="_blank"
											rel="noopener noreferrer"
											class="rounded-full border border-text-300 p-2 text-text-700 hover:bg-text-100 dark:border-text-700 dark:text-text-200 dark:hover:bg-text-900"
											aria-label={`Repositorio del proyecto ${project.data.title}`}
										>
											<Link2 size={18} />
										</a>
									)}

									{project.data.liveUrl && (
										<a
											href={project.data.liveUrl}
											target="_blank"
											rel="noopener noreferrer"
											class="rounded-full border border-text-300 p-2 text-text-700 hover:bg-text-100 dark:border-text-700 dark:text-text-200 dark:hover:bg-text-900"
											aria-label={`Demo del proyecto ${project.data.title}`}
										>
											<Globe size={18} />
										</a>
									)}
								</div>
							</article>
						))}
					</div>
				</section>
			))}
		</div>
	</MainContainerSection>
</BaseLayout>

<script>
	const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]');
	const cards = document.querySelectorAll<HTMLElement>('[data-project-card]');
	const groups = document.querySelectorAll<HTMLElement>('[data-project-group]');

	const toggleGroups = () => {
		groups.forEach((group) => {
			const visibleCards = group.querySelectorAll('[data-project-card]:not(.hidden)').length;
			group.classList.toggle('hidden', visibleCards === 0);
		});
	};

	filterButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const selected = btn.getAttribute('data-tag-filter');

			filterButtons.forEach((item) => {
				const active = item === btn;
				item.setAttribute('data-active', active ? 'true' : 'false');
				item.classList.toggle('bg-primary-600', active);
				item.classList.toggle('text-white', active);
			});

			cards.forEach((card) => {
				const tags = card.getAttribute('data-project-tags') ?? '';
				const show = selected === 'all' || tags.split('|').includes(selected ?? '');
				card.classList.toggle('hidden', !show);
			});

			toggleGroups();
		});
	});

	toggleGroups();
</script>
