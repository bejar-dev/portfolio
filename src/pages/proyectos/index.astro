---
import { getCollection } from 'astro:content';
import { Link2, Globe } from '@lucide/astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MainContainerSection from '../../components/ui/MainContainerSection.astro';
import HeaderSection from '../../components/ui/HeaderSection.astro';

const allProjects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const tags = [...new Set(allProjects.flatMap((project) => project.data.tags))].sort();
---

<BaseLayout title="Proyectos">
	<MainContainerSection class="pt-20">
		<HeaderSection title="Proyectos" subtitle="Listado completo de trabajos y experimentos recientes." />

		<div class="mb-8 flex flex-wrap gap-2" aria-label="Filtrar proyectos por tag">
			<button
				type="button"
				class="rounded-full border border-text-300 px-4 py-2 text-sm font-medium transition hover:bg-text-100 dark:border-text-700 dark:hover:bg-text-900"
				data-tag-filter="all"
				data-active="true"
			>
				Todos
			</button>
			{tags.map((tag) => (
				<button
					type="button"
					class="rounded-full border border-text-300 px-4 py-2 text-sm font-medium transition hover:bg-text-100 dark:border-text-700 dark:hover:bg-text-900"
					data-tag-filter={tag}
				>
					{tag}
				</button>
			))}
		</div>

		<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3" id="project-grid">
			{allProjects.map((project) => (
				<article
					class="flex h-full flex-col rounded-2xl border border-text-200 bg-white/75 p-5 shadow-sm dark:border-text-800 dark:bg-text-950/70"
					data-project-tags={project.data.tags.join('|')}
				>
					  <a href={`/proyectos/${project.id}`} class="group block">
						<div class="mb-4 rounded-xl bg-gradient-to-br from-primary-200 via-secondary-100 to-complement-200 p-6 dark:from-primary-900 dark:via-secondary-900 dark:to-complement-900">
							<h3 class="font-bold text-text-900 group-hover:underline dark:text-text-50">{project.data.title}</h3>
						</div>
					</a>

					<p class="text-text-700 dark:text-text-200">{project.data.shortDescription}</p>

					<div class="mt-4 flex flex-wrap gap-2">
						{project.data.tags.map((tag) => (
							<span class="rounded-full bg-primary-100 px-2.5 py-1 text-xs font-semibold text-primary-700 dark:bg-primary-900 dark:text-primary-200">
								{tag}
							</span>
						))}
					</div>

					<div class="mt-auto flex items-center gap-2 pt-5">
						{project.data.github && (
							<a
								href={project.data.github}
								target="_blank"
								rel="noopener noreferrer"
								class="rounded-full border border-text-300 p-2 text-text-700 hover:bg-text-100 dark:border-text-700 dark:text-text-200 dark:hover:bg-text-900"
								aria-label={`Repositorio del proyecto ${project.data.title}`}
							>
								<Link2 size={18} />
							</a>
						)}

						{project.data.liveUrl && (
							<a
								href={project.data.liveUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="rounded-full border border-text-300 p-2 text-text-700 hover:bg-text-100 dark:border-text-700 dark:text-text-200 dark:hover:bg-text-900"
								aria-label={`Demo del proyecto ${project.data.title}`}
							>
								<Globe size={18} />
							</a>
						)}
					</div>
				</article>
			))}
		</div>
	</MainContainerSection>
</BaseLayout>

<script>
	const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-tag-filter]');
	const cards = document.querySelectorAll<HTMLElement>('[data-project-tags]');

	filterButtons.forEach((btn) => {
		btn.addEventListener('click', () => {
			const selected = btn.getAttribute('data-tag-filter');

			filterButtons.forEach((item) => {
				const active = item === btn;
				item.setAttribute('data-active', active ? 'true' : 'false');
				item.classList.toggle('bg-primary-600', active);
				item.classList.toggle('text-white', active);
			});

			cards.forEach((card) => {
				const tags = card.getAttribute('data-project-tags') ?? '';
				const show = selected === 'all' || tags.split('|').includes(selected ?? '');
				card.classList.toggle('hidden', !show);
			});
		});
	});
</script>
