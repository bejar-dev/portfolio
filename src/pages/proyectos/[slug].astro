---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import Schema from '../../components/seo/Schema.astro';
import ProjectHeroSection from '../../components/sections/projects/ProjectHeroSection.astro';
import ProjectQuickProofSection from '../../components/sections/projects/ProjectQuickProofSection.astro';
import ProjectRoleScopeSection from '../../components/sections/projects/ProjectRoleScopeSection.astro';
import ProjectProblemSolutionSection from '../../components/sections/projects/ProjectProblemSolutionSection.astro';
import ProjectGallerySection from '../../components/sections/projects/ProjectGallerySection.astro';
import ProjectBodySection from '../../components/sections/projects/ProjectBodySection.astro';
import ProjectLearningsSection from '../../components/sections/projects/ProjectLearningsSection.astro';
import ProjectCTASection from '../../components/sections/projects/ProjectCTASection.astro';
import ProjectRelatedSection from '../../components/sections/projects/ProjectRelatedSection.astro';
import ProjectMdxH2 from '../../components/sections/projects/mdx/ProjectMdxH2.astro';
import ProjectMdxH3 from '../../components/sections/projects/mdx/ProjectMdxH3.astro';
import ProjectMdxParagraph from '../../components/sections/projects/mdx/ProjectMdxParagraph.astro';
import ProjectMdxUl from '../../components/sections/projects/mdx/ProjectMdxUl.astro';
import ProjectMdxOl from '../../components/sections/projects/mdx/ProjectMdxOl.astro';
import ProjectMdxLi from '../../components/sections/projects/mdx/ProjectMdxLi.astro';
import ProjectMdxBlockquote from '../../components/sections/projects/mdx/ProjectMdxBlockquote.astro';
import { personal } from '../../data/personal';

const experienceLabels: Record<string, string> = {
	'bcp-consulting-eirl': 'BCP Consulting EIRL',
	'consigue-ventas-eirl': 'Consigue Ventas EIRL',
	'creanding-eirl': 'Creanding EIRL',
	'orbita-labs': 'Orbita Labs',
	independiente: 'Proyecto independiente'
};

export async function getStaticPaths() {
	const projects = await getCollection('projects');

	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project }
	}));
}

const { project } = Astro.props as { project: CollectionEntry<'projects'> };
const { Content } = await render(project);
const allProjects = await getCollection('projects');

const groupLabel =
	project.data.experienceGroupLabel ??
	(project.data.experienceGroup ? experienceLabels[project.data.experienceGroup] : undefined);

const projectSchema = {
	title: project.data.title,
	description: project.data.shortDescription,
	image: project.data.image,
	github: project.data.github,
	liveUrl: project.data.liveUrl,
	date: project.data.date,
	keywords: project.data.tags,
	schemaType: project.data.schemaType
};

const imageSet = project.data.gallery?.length ? project.data.gallery : project.data.image ? [project.data.image] : [];

const images = imageSet.map((src, index) => ({
	src,
	alt: `Captura ${index + 1} del proyecto ${project.data.title}`
}));

const relatedProjects = allProjects
	.filter((candidate) => candidate.id !== project.id)
	.filter((candidate) => {
		if (project.data.experienceGroup && candidate.data.experienceGroup === project.data.experienceGroup) {
			return true;
		}

		return candidate.data.tags.some((tag) => project.data.tags.includes(tag));
	})
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
	.slice(0, 3)
	.map((candidate) => ({
		...candidate,
		data: {
			...candidate.data,
			experienceGroupLabel:
				candidate.data.experienceGroupLabel ??
				(candidate.data.experienceGroup
					? experienceLabels[candidate.data.experienceGroup]
					: undefined)
		}
	}));

const mdxComponents = {
	h2: ProjectMdxH2,
	h3: ProjectMdxH3,
	p: ProjectMdxParagraph,
	ul: ProjectMdxUl,
	ol: ProjectMdxOl,
	li: ProjectMdxLi,
	blockquote: ProjectMdxBlockquote
};
---

<ProjectLayout title={`${project.data.title} | Proyectos`} description={project.data.shortDescription} image={project.data.image} type="article">
	<Schema
		name={personal.name}
		jobTitle={personal.role}
		url={new URL('/', Astro.site ?? Astro.url).toString()}
		sameAs={[personal.social.github, personal.social.linkedin]}
		projectData={projectSchema}
	/>

	<ProjectHeroSection
		title={project.data.title}
		description={project.data.description}
		shortDescription={project.data.shortDescription}
		role={project.data.role}
		experienceGroupLabel={groupLabel}
		date={project.data.date}
		liveUrl={project.data.liveUrl}
		github={project.data.github}
	/>

	{project.data.impactMetrics && project.data.impactMetrics.length > 0 && (
		<ProjectQuickProofSection metrics={project.data.impactMetrics} />
	)}

	<ProjectRoleScopeSection
		experienceGroupLabel={groupLabel}
		experienceRoleSummary={project.data.experienceRoleSummary}
		role={project.data.role}
		duration={project.data.duration}
		tags={project.data.tags}
	/>

	{(project.data.problem || project.data.solution) && (
		<ProjectProblemSolutionSection problem={project.data.problem} solution={project.data.solution} />
	)}

	{images.length > 0 && <ProjectGallerySection images={images} />}

	<ProjectBodySection>
		<Content components={mdxComponents} />
	</ProjectBodySection>

	{project.data.lessons && project.data.lessons.length > 0 && (
		<ProjectLearningsSection lessons={project.data.lessons} />
	)}

	<ProjectCTASection liveUrl={project.data.liveUrl} github={project.data.github} cta={project.data.cta} />

	{relatedProjects.length > 0 && <ProjectRelatedSection projects={relatedProjects} />}
</ProjectLayout>

<style>
	#project-content h2 {
		margin-top: 2rem;
	}
</style>