---
import '../styles/global.css';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import MetaTags from '../components/seo/MetaTags.astro';
import Schema from '../components/seo/Schema.astro';
import { personal } from '../data/personal';

interface Props {
	title: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
	type?: 'website' | 'article';
}

const {
	title,
	description = personal.bio,
	image,
	canonicalURL,
	type = 'website'
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Favicon: SVG para navegadores modernos, ICO como fallback universal -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />

		<!-- PNG explícito para contextos que no soporten SVG -->
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />

		<!-- iOS: icono al guardar en pantalla de inicio -->
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

		<!-- PWA / Android: manifest con los iconos 192 y 512 -->
		<link rel="manifest" href="/site.webmanifest" />

		<!-- Color de la barra del navegador en mobile -->
		<meta name="theme-color" content="#tu-color-primario" />

		<script is:inline>
			(() => {
				const stored = localStorage.getItem('theme');
				const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				const theme = stored ?? (systemPrefersDark ? 'dark' : 'light');
				document.documentElement.classList.toggle('dark', theme === 'dark');
			})();
		</script>

		<MetaTags
			title={title}
			description={description}
			image={image}
			canonicalURL={canonicalURL}
			type={type}
		/>
		<Schema
			name={personal.name}
			jobTitle={personal.role}
			url={new URL('/', Astro.site ?? Astro.url).toString()}
			sameAs={[personal.social.github, personal.social.linkedin]}
		/>
	</head>
	<body class="text-text-900 dark:text-text-100 antialiased">
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
